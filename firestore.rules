rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user can create/update only their own subscriber record
    // (their uid must match the document id). The app owner can read every
    // subscriber's record so they can see who signed up and where; everyone
    // else can only read their own.
    match /subscribers/{uid} {
      allow read: if request.auth != null &&
        (request.auth.uid == uid || request.auth.token.email == 'williamwilson25@icloud.com');
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Crowd-sourced storm reports. Anyone signed in can submit one (always
    // starting as 'pending'); approved reports are readable by everyone,
    // pending/rejected ones only by their own author or the app owner, who
    // is also the only one allowed to change status (moderation).
    match /stormReports/{reportId} {
      allow create: if request.auth != null &&
        request.resource.data.submittedByUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow read: if resource.data.status == 'approved' ||
        (request.auth != null &&
          (request.auth.uid == resource.data.submittedByUid ||
            request.auth.token.email == 'williamwilson25@icloud.com'));
      allow update: if request.auth != null && request.auth.token.email == 'williamwilson25@icloud.com';
    }

    // "Will's Weather Desk" — a single owner-editable message shown to
    // everyone on the Home tab. Any signed-in user can read it; only the
    // owner can write it.
    match /siteContent/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'williamwilson25@icloud.com';
    }
  }
}
