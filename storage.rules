rules_version = '2';

// Nothing in the app uploads to Storage anymore (Storm Reports, the only
// feature that did, was removed) — deny by default rather than leaving an
// open write rule for a path nothing writes to.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
